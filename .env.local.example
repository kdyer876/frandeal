# ─── Database ──────────────────────────────────────────────────────────────────
# Get from Supabase, Neon, or Railway. SHARED with the fdd-platform project —
# both apps point at the same DATABASE_URL.
DATABASE_URL=postgres://user:pass@host:5432/frandeal

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-64-char-random-hex

# ─── Email ─────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=resend
EMAIL_FROM=alerts@frandeal.com
EMAIL_FROM_NAME=FranDeal
RESEND_API_KEY=re_...

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://frandeal.com

# URL of the sister FDD-lookup site. Used to link from each listing's
# FDD section to the full FDD breakdown.
NEXT_PUBLIC_FDDPULSE_URL=https://fdd.frandeal.com

# ─── Cron security ─────────────────────────────────────────────────────────────
# Used to authenticate Vercel Cron requests to /api/cron/*
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=replace-with-32-char-random-hex
